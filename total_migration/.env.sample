# =========================
# Nextcloud / Web
# =========================
NEXTCLOUD_VERSION=25.0.13-apache
NEXTCLOUD_PORT=8080

# =========================
# Nextcloud / Datenbank
# =========================
MYSQL_HOST=db
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=bitte-ein-starkes-db-passwort-setzen

# =========================
# MySQL Root
# =========================
MYSQL_ROOT_PASSWORD=bitte-ein-starkes-root-passwort-setzen

# =========================
# Redis
# =========================
REDIS_HOST=redis

# =========================
# Proxy (optional)
# Leer lassen, wenn kein Proxy genutzt wird.
# =========================
http_proxy=
https_proxy=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# =========================
# Mount-Pfade (Host), stage-unabhaengig
# Relativ zur jeweiligen Compose-Datei oder als absoluter Host-Pfad
# =========================
DB_MOUNT_PATH=./db
REDIS_MOUNT_PATH=./redis
NEXTCLOUD_CONFIG_MOUNT_PATH=./config
NEXTCLOUD_APPS_EXTERNAL_MOUNT_PATH=./apps-external
NEXTCLOUD_DATA_MOUNT_PATH=./data
NEXTCLOUD_VERSION_FILE_MOUNT_PATH=./version.php
# Nur fuer stage0 (Full-Mount auf /var/www/html); in anderen Stages nicht verwenden.
NEXTCLOUD_HTML_MOUNT_PATH=./nextcloud
