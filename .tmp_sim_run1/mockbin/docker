#!/usr/bin/env bash
set -euo pipefail

cmd="$1"
shift

case "$cmd" in
  inspect)
    [ "${1:-}" = "--format" ] || exit 1
    fmt="${2:-}"
    container="${3:-}"
    [ "$container" = "demo-db" ] || exit 1
    case "$fmt" in
      '{{.State.Running}}')
        echo true
        ;;
      '{{if .State.Health}}{{.State.Health.Status}}{{else}}no-healthcheck{{end}}')
        echo healthy
        ;;
      *)
        exit 1
        ;;
    esac
    ;;
  exec)
    cat >/dev/null || true
    exit 0
    ;;
  *)
    exit 1
    ;;
esac
